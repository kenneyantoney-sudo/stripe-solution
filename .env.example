# =====================================================================
# FoodNow — Stripe demo environment (TEST MODE ONLY)
# Copy this file to ".env" and fill in your own TEST keys.
#   cp .env.example .env
# The real ".env" is gitignored. NEVER commit real keys.
# =====================================================================

# --- Stripe TEST keys (Dashboard > Developers > API keys) ---
# Secret key is used ONLY on the server. It must never reach the browser.
STRIPE_SECRET_KEY=sk_test_xxx
# Publishable key is safe to expose in the browser.
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Local webhook signing secret ---
# When you run `stripe listen`, the CLI prints a secret like "whsec_...".
# Paste it here so the server can VERIFY each webhook's signature.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- OPTIONAL: Stripe Connect marketplace split ---
# Leave BLANK for a simple single charge.
# Set to a connected account id (acct_...) to turn the payment into a
# DESTINATION CHARGE: 20% platform fee retained, remainder sent to the
# restaurant/driver's connected account.
CONNECTED_ACCOUNT_ID=

# --- Local server port ---
PORT=4242
